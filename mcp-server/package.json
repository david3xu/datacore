{
  "name": "datacore-mcp-server",
  "version": "0.1.0",
  "private": true,
  "description": "Phase 1 local stdio MCP server for datacore",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "node src/index.mjs",
    "smoke": "node scripts/smoke.mjs",
    "autolog:smoke": "node scripts/autolog-smoke.mjs",
    "inspect": "bash scripts/inspect.sh",
    "format": "npx prettier --write src/ tests/",
    "format:check": "npx prettier --check src/ tests/",
    "test": "node --test tests/*.test.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "prettier": "^3.8.1"
  }
}
