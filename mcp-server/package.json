{
  "name": "datacore-mcp-server",
  "version": "0.1.0",
  "private": true,
  "description": "Phase 1 local stdio MCP server for datacore",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "smoke": "node scripts/smoke.mjs",
    "autolog:smoke": "node scripts/autolog-smoke.mjs",
    "inspect": "bash scripts/inspect.sh",
    "format": "npx prettier --write src/ tests/",
    "format:check": "npx prettier --check src/ tests/",
    "lint": "npx eslint src/*.ts",
    "pretest": "pnpm run build",
    "test": "node --test tests/*.test.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "typescript": "5.8",
    "typescript-eslint": "^8.57.2"
  }
}
